{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    "src/app/(admin)/admin/page.jsx",
    "src/app/(admin)/admin/orders/page.jsx",
    "src/app/(admin)/admin/products/page.jsx",
    "src/app/(admin)/admin/settings/page.jsx",
    "src/app/(admin)/layout.jsx",
    "src/app/(admin)/admin/categories/[id]/edit/page.jsx",
    "src/app/(admin)/admin/categories/new/page.jsx",
    "src/app/(admin)/admin/categories/page.jsx"
  ],
  "exclude": ["node_modules"]
}
